# ============================================================
# Recipe Factory — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# OpenAI — Required for AI recipe generation
# Get your key at: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# Google Service Account — Required for Google Sheets integration
# Create a service account at: https://console.cloud.google.com/
# Share your keyword sheet with the service account email.
# Paste the private key exactly as shown in the JSON file
# (including the -----BEGIN/END----- lines, newlines as \n).
# ------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ------------------------------------------------------------
# Pexels API — Required for auto-fetching recipe images (free)
# Get your key at: https://www.pexels.com/api/
# ------------------------------------------------------------
PEXELS_API_KEY=

# ------------------------------------------------------------
# Vercel Deployment — Required to deploy generated recipe sites
# Create a token at: https://vercel.com/account/tokens
# VERCEL_TEAM_ID is only needed if deploying to a Vercel team.
# ------------------------------------------------------------
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ------------------------------------------------------------
# Factory Database (Supabase) — Optional
# Without this, data is stored in memory (lost on server restart).
# Create a project at: https://supabase.com
# Run the SQL migration from the Setup Guide to create tables.
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Dashboard Authentication — Optional
# Set a password to protect the factory dashboard.
# Leave empty to disable authentication entirely.
# ------------------------------------------------------------
FACTORY_PASSWORD=

# ------------------------------------------------------------
# Vercel Cron Secret — Highly Recommended for production
# Vercel sends this as "Authorization: Bearer <CRON_SECRET>"
# when calling /api/cron/run-schedules. Without it, anyone
# can trigger generation runs by hitting that endpoint.
# Set the same value in your Vercel project env vars.
# Generate one: openssl rand -hex 32
# ------------------------------------------------------------
CRON_SECRET=
