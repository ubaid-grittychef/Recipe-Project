# === REQUIRED ===

# OpenAI — for AI recipe generation
OPENAI_API_KEY=sk-your-openai-api-key

# Google Sheets — for reading keywords
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"

# Vercel — for deploying recipe sites
VERCEL_TOKEN=your-vercel-api-token

# Pexels — for recipe images (free: https://www.pexels.com/api/)
PEXELS_API_KEY=your-pexels-api-key

# Factory dashboard password (leave empty to disable auth)
FACTORY_PASSWORD=your-secret-password

# === OPTIONAL ===

# Vercel team (only if deploying to a team account)
VERCEL_TEAM_ID=

# Factory database (without this, data lives in memory — dev only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
